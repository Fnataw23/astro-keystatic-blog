---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryTranslations: Record<string, string> = {
  construction: 'Строительство',
  renovation: 'Ремонт и отделка',
  plumbing: 'Сантехника',
  electrical: 'Электрика',
  design: 'Дизайн интерьера',
};

// Date formatter
const formatDate = (date: Date) => {
  return date.toLocaleDateString('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};

// Video URL converter to embed version
function getEmbedUrl(url: string | undefined): string | null {
  if (!url) return null;
  
  try {
    // YouTube
    if (url.includes('youtube.com') || url.includes('youtu.be')) {
      let videoId = '';
      if (url.includes('youtu.be/')) {
        videoId = url.split('youtu.be/')[1].split(/[?#]/)[0];
      } else if (url.includes('v=')) {
        videoId = url.split('v=')[1].split(/[&#]/)[0];
      } else if (url.includes('embed/')) {
        return url;
      }
      return videoId ? `https://www.youtube-nocookie.com/embed/${videoId}` : url;
    }
    
    // Rutube
    if (url.includes('rutube.ru')) {
      if (url.includes('rutube.ru/play/embed/')) {
        return url;
      }
      // Matches rutube.ru/video/xxxxxx/
      const match = url.match(/rutube\.ru\/video\/([a-zA-Z0-9]+)/);
      if (match && match[1]) {
        return `https://rutube.ru/play/embed/${match[1]}`;
      }
      return url;
    }

    // VK Video
    if (url.includes('vk.com/video') || url.includes('vkvideo.ru')) {
      // Return directly or let them use the iframe code. If they paste a regular link, we note it.
      return url;
    }
    
    return url;
  } catch (e) {
    return url;
  }
}

const embedVideoUrl = getEmbedUrl(post.data.videoUrl);
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{post.data.title} — МастерБлог</title>
  <meta name="description" content={post.data.description}>
</head>
<body>

  <!-- Navigation -->
  <nav class="navbar">
    <div class="container navbar-inner">
      <a href="/" class="logo">
        МастерБлог
        <span class="logo-dot"></span>
      </a>
      <div class="nav-links">
        <a href="/" class="nav-link">Главная</a>
        <a href="/keystatic" class="admin-btn" target="_blank">Админ-панель ↗</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <article>
      <!-- Article Header -->
      <header class="article-header">
        <a href="/" style="
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          color: var(--accent);
          font-weight: 600;
          font-size: 0.9rem;
          margin-bottom: 1.5rem;
          transition: var(--transition);
        " class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Назад к списку статей
        </a>
        
        <h1 class="article-title">{post.data.title}</h1>
        
        <div class="article-meta">
          <span class={`badge badge-${post.data.category}`}>
            {categoryTranslations[post.data.category]}
          </span>
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
        </div>
      </header>

      <!-- Article Cover -->
      {post.data.coverImage && (
        <div class="article-cover-container">
          <img src={post.data.coverImage} alt={post.data.title} class="article-cover" />
        </div>
      )}

      <!-- Article Body -->
      <section class="article-body">
        <Content />
        
        <!-- Video Player Section (if uploaded file is present) -->
        {post.data.videoFile && (
          <div class="video-section" style="margin-top: 3.5rem;">
            <h2 style="margin-bottom: 1.5rem;">Видео по теме:</h2>
            <div style="margin: 2rem 0;">
              <video
                src={post.data.videoFile}
                controls
                style="width: 100%; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-lg), var(--glow-shadow);"
              ></video>
            </div>
          </div>
        )}

        <!-- Video Player Section (if external videoUrl is present and no local video) -->
        {!post.data.videoFile && embedVideoUrl && (
          <div class="video-section" style="margin-top: 3.5rem;">
            <h2 style="margin-bottom: 1.5rem;">Видео по теме:</h2>
            <div class="video-wrapper">
              <iframe
                src={embedVideoUrl}
                title={`Видео: ${post.data.title}`}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        )}
      </section>
    </article>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <p>© 2026 МастерБлог. Все права защищены.</p>
      <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--text-muted);">
        Сделано с использованием Astro + Keystatic
      </p>
      <div class="footer-links">
        <a href="/" style="color: var(--text-muted);">Главная</a>
        <a href="/keystatic" style="color: var(--text-muted);">Админ-панель</a>
      </div>
    </div>
  </footer>

  <style>
    .back-link:hover {
      color: var(--accent-secondary);
      transform: translateX(-4px);
    }
  </style>
</body>
</html>
